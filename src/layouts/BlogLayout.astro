---
import BaseLayout from './BaseLayout.astro';
import Navbar from '@/components/ui/Navbar';
import Footer from '@/components/ui/Footer';
import VisitCounter from '@/components/blog/VisitCounter';
import CommentSection from '@/components/blog/CommentSection';
import DroneBackToTop from '@/components/ui/DroneBackToTop';
import TableOfContents from '@/components/blog/TableOfContents';

import '@/styles/pretext.css';

interface Props {
  title: string;
  pubDate: string;
  description?: string;
  slug?: string;
  tags?: string[];
  series?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, pubDate, description, slug = '', tags = [], series = '', headings = [] } = Astro.props;
const pagePath = slug ? `/blog/${slug}` : Astro.url.pathname;
const backLink = series === 'blender' ? '/blog/blender' : '/blog';
const backText = series === 'blender' ? 'Back to Blender Notes' : 'Back to Blog';
---

<BaseLayout title={`${title} | Blog`} description={description}>
  <Navbar client:load />
  
  <div class="max-w-[100rem] mx-auto px-4 lg:px-8 xl:px-12 py-24 flex xl:gap-8 2xl:gap-16 items-start justify-center">
    {/* Left Sidebar Table of Contents */}
    <aside class="hidden xl:flex flex-col w-[16rem] 2xl:w-[18rem] shrink-0 sticky top-24 pt-8 h-[calc(100vh-6rem)] relative z-10 pr-2 xl:pr-6">
      <TableOfContents client:load headings={headings} />
    </aside>

    {/* Main Content Area */}
    <main class="w-full max-w-full lg:max-w-5xl xl:max-w-[62rem] 2xl:max-w-[72rem]">
      <a
        href={backLink}
        class="inline-flex items-center gap-2 text-sm mb-8 transition-colors group"
        style="color: var(--color-primary);"
      >
        <span class="transition-transform group-hover:-translate-x-1">←</span> {backText}
      </a>
      <article class="pretext-design prose-lg max-w-none w-full">
        <header class="mb-10 not-prose">
          <div class="flex items-center gap-3 flex-wrap mb-3">
            <time class="text-sm px-2.5 py-0.5 rounded-full" style="color: var(--color-text-muted); background: var(--color-bg-secondary);">
              {pubDate}
            </time>
            <VisitCounter client:load pagePath={pagePath} />
          </div>
          <h1 class="text-3xl md:text-4xl font-bold mt-2 mb-4 leading-tight" style="color: var(--color-text);">
            {title}
          </h1>
          {description && (
            <p class="text-base leading-relaxed mb-4" style="color: var(--color-text-muted);">
              {description}
            </p>
          )}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag: string) => (
                <span
                  class="text-xs px-2.5 py-1 rounded-full font-medium"
                  style="background: rgba(99, 102, 241, 0.08); color: var(--color-primary); border: 1px solid rgba(99, 102, 241, 0.15);"
                >
                  #{tag}
                </span>
              ))}
            </div>
          )}
          <div class="mt-6 h-px" style="background: linear-gradient(90deg, var(--color-primary), var(--color-accent), transparent);" />
        </header>
        <slot />
      </article>

      <div class="xl:hidden">
        <TableOfContents client:load headings={headings} isMobile={true} />
      </div>

      <CommentSection client:visible pagePath={pagePath} />
    </main>

    {/* Right padding filler for centering balance, slightly narrower than left sidebar to push content slightly right */}
    <div class="hidden xl:block w-[14rem] 2xl:w-[16rem] shrink-0 pointer-events-none"></div>
  </div>
  <DroneBackToTop client:load />
  <Footer client:visible />
</BaseLayout>
