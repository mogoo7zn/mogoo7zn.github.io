---
import BaseLayout from './BaseLayout.astro';
import Navbar from '@/components/ui/Navbar';
import Footer from '@/components/ui/Footer';
import VisitCounter from '@/components/blog/VisitCounter';
import CommentSection from '@/components/blog/CommentSection';
import DroneBackToTop from '@/components/ui/DroneBackToTop';
import TableOfContents from '@/components/blog/TableOfContents';

import '@/styles/pretext.css';

interface Props {
  title: string;
  pubDate?: string;
  venue?: string;
  authors?: string[];
  slug?: string;
  tags?: string[];
  pdf?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, pubDate, venue, authors = [], slug = '', tags = [], pdf, headings = [] } = Astro.props;
const pagePath = slug ? `/publications/${slug}` : Astro.url.pathname;
const backLink = '/publications';
const backText = '返回 Publications 栏目 (Back to Publications)';
---

<BaseLayout title={`${title} | Publication`}>
  <Navbar client:load />
  
  <div class="max-w-[104rem] mx-auto px-4 lg:px-8 xl:px-12 py-24 flex xl:gap-10 2xl:gap-14 items-start justify-center">
    {/* Left Sidebar Table of Contents */}
    <aside class="hidden xl:flex flex-col w-[16rem] 2xl:w-[18rem] shrink-0 sticky top-24 pt-8 h-[calc(100vh-6rem)] relative z-10 pr-2 xl:pr-6">
      <TableOfContents client:load headings={headings} />
    </aside>

    {/* Main Content Area */}
    <main class="w-full max-w-full lg:max-w-5xl xl:max-w-[64rem] 2xl:max-w-[74rem] xl:ml-2 2xl:ml-3">
      <a
        href={backLink}
        class="inline-flex items-center gap-2 text-sm mb-8 transition-colors group"
        style="color: var(--color-primary);"
      >
        <span class="transition-transform group-hover:-translate-x-1">←</span> {backText}
      </a>
      <article class="pretext-design prose-lg max-w-none w-full">
        <header class="mb-10 not-prose">
          <div class="flex items-center gap-3 flex-wrap mb-3">
            {pubDate && (
              <time class="text-sm px-2.5 py-0.5 rounded-full" style="color: var(--color-text-muted); background: var(--color-bg-secondary);">
                {pubDate}
              </time>
            )}
            {venue && (
              <span class="text-sm px-2.5 py-0.5 rounded-full font-medium" style="color: var(--color-accent); background: var(--color-bg-secondary);">
                {venue}
              </span>
            )}
            <VisitCounter client:load pagePath={pagePath} />
          </div>
          <h1 class="text-3xl md:text-4xl font-bold mt-2 mb-4 leading-tight" style="color: var(--color-text);">
            {title}
          </h1>
          {authors.length > 0 && (
            <p class="text-base leading-relaxed mb-4" style="color: var(--color-text-secondary);">
              {authors.join(', ')}
            </p>
          )}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag: string) => (
                <span
                  class="text-xs px-2.5 py-1 rounded-full font-medium"
                  style="background: rgba(99, 102, 241, 0.08); color: var(--color-primary); border: 1px solid rgba(99, 102, 241, 0.15);"
                >
                  #{tag}
                </span>
              ))}
            </div>
          )}
          <div class="mt-6 h-px" style="background: linear-gradient(90deg, var(--color-primary), var(--color-accent), transparent);" />
        </header>
        <slot />
      </article>

      {pdf && (
        <div class="mt-12 mb-10">
          <h2 class="text-2xl font-bold mb-4" style="color: var(--color-text);">论文文档 (Paper Document)</h2>
          <div class="w-full relative rounded-xl overflow-hidden" style="padding-top: 141.4%; border: 1px solid var(--color-border); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
            <iframe 
              src={pdf} 
              class="absolute inset-0 w-full h-full border-none"
              title="PDF Viewer"
            ></iframe>
          </div>
          <div class="mt-3 text-right">
            <a href={pdf} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline" style="color: var(--color-primary);">
              在新标签页中打开 PDF (Open PDF in new tab) ↗
            </a>
          </div>
        </div>
      )}

      <div class="xl:hidden">
        <TableOfContents client:load headings={headings} isMobile={true} />
      </div>

      <CommentSection client:visible pagePath={pagePath} />
    </main>

    {/* Right padding filler for centering balance, slightly narrower than left sidebar to push content slightly right */}
    <div class="hidden xl:block w-[8rem] 2xl:w-[10rem] shrink-0 pointer-events-none"></div>
  </div>
  <DroneBackToTop client:load />
  <Footer client:visible />
</BaseLayout>
