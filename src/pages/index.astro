---
import PageLayout from '@/layouts/PageLayout.astro';
import Navbar from '@/components/ui/Navbar';
import LoadingScreen from '@/components/ui/LoadingScreen';
import ScrollProgress from '@/components/ui/ScrollProgress';
import DroneBackToTop from '@/components/ui/DroneBackToTop';

import Hero from '@/components/sections/Hero';
import About from '@/components/sections/About';
import Projects from '@/components/sections/Projects';
import Skills from '@/components/sections/Skills';
import Timeline from '@/components/sections/Timeline';
import CV from '@/components/sections/CV';
import Footer from '@/components/ui/Footer';

import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const validBlogSlugs = posts.filter(post => !post.data.draft).map(post => post.slug);
---

<PageLayout>
  <LoadingScreen client:load />
  <ScrollProgress client:load />
  <Navbar client:load />
  <DroneBackToTop client:load />
  <main>
    <Hero client:load />
    <About client:visible />
    <Projects client:visible validBlogSlugs={validBlogSlugs} />
    <Skills client:load />
    <Timeline client:visible />
    <CV client:visible />
  </main>

  <Footer client:visible />
</PageLayout>
